<div id="digest-rules-settings">
  <% if User.current.allowed_to?(:manage_digest_rules, @project) %>
    <p>
      <%= link_to l(:label_new_issue_digest_rule),
                  new_project_issue_digest_rule_path(@project),
                  class: 'icon icon-add' %>
    </p>
  <% end %>

  <%# This partial is rendered by ProjectsController#settings, which provides no
      plugin-specific before_action. DB queries here are unavoidable — there is no
      hook to preload @rules and @latest_runs in the controller. %>
  <% rules = IssueDigestRule.where(project_id: @project.id).order(:name) %>
  <% latest_runs = IssueDigest::RunLookup.latest_by_rule_id(rules) %>

  <% if rules.empty? %>
    <p class="nodata"><%= l(:text_no_digest_rules) %></p>
  <% else %>
    <table class="list">
      <thead>
        <tr>
          <th scope="col"><%= l(:field_name) %></th>
          <th scope="col"><%= l(:field_schedule_type) %></th>
          <th scope="col"><%= l(:field_recipient_modes) %></th>
          <th scope="col"><%= l(:field_status) %></th>
          <th scope="col"><%= l(:label_run_history_last) %></th>
          <th scope="col"></th>
        </tr>
      </thead>
      <tbody>
        <% label_cache = recipient_label_cache(rules) %>
        <% rules.each do |rule| %>
          <%= render partial: 'issue_digest_rules/rule_row',
                     locals: { rule: rule, latest_run: latest_runs[rule.id], label_cache: label_cache } %>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
